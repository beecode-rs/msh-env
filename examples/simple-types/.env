# --- All types, REQUIRED ---
SIMPLE_STRING=hello-world
SIMPLE_NUMBER=42
SIMPLE_BOOLEAN=true
SIMPLE_JSON={"key":"value","nested":{"n":1}}
# base64 for "hello from msh-env"
SIMPLE_BASE64=aGVsbG8gZnJvbSBtc2gtZW52

# --- OPTIONAL (present) ---
OPTIONAL_STRING=optional-present

# --- ALLOWED (must be one of the listed values) ---
ALLOWED_STRING=prod
ALLOWED_NUMBER=2

# NOTE:
# OPTIONAL_MISSING_STRING is intentionally not set -> resolves to undefined
# DEFAULT_MISSING_STRING  is intentionally not set -> uses the default value
# DEFAULT_MISSING_NUMBER  is intentionally not set -> uses the default value
