{
	"compilerOptions": {
		"emitDecoratorMetadata": true,
		"isolatedModules": true,
		"alwaysStrict": true,
		"baseUrl": ".",
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"lib": ["es2020"],
		"module": "es2015",
		"moduleResolution": "node",
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noImplicitThis": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"outDir": "lib",
		"paths": {
			"src/*": ["src/*"]
		},
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"strictFunctionTypes": true,
		"strictNullChecks": true,
		"target": "esnext"
	},
	"include": ["src/**/*.ts"]
}
